# Copy this file to .env and fill in your Alpaca credentials.
# NEVER commit .env or share these keys with Claude Code or any AI tool.

ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# Optional: webhook alerts (Slack / Discord)
ALERT_WEBHOOK_URL=
